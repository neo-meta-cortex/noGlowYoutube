{
  "manifest_version": 3,
  "name": "No Glow Youtube",
  "version": "1.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "neo@metacortex.hax",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}